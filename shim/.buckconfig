[buildfile]
# see <https://github.com/facebook/kuro/pull/956> -- this helps us make
# error messages when the user doesn't run "reindeer" much more obvious.
# We then make reindeer generate BUCK.reindeer to override the default.
name = BUCK.reindeer,BUILD.bazel

[cells]
gh_facebook_kuro_shims_meta = .

[cell_aliases]
root = gh_facebook_kuro_shims_meta

# This is a duplicate of .buckconfig.d/common.buckconfig, but due to the way
# we vendor the shim directory, common.buckconfig won't show up in the
# vendored .buckconfig.d directory.
# When the shim cell is no longer vendored in individual projects, this
# duplication can be removed.
[cells]
# prelude = prelude  # DISABLED: Phase 8c-interim
none = none

[cell_aliases]
# config = prelude  # DISABLED: Phase 8c-interim
# ovr_config = prelude  # DISABLED: Phase 8c-interim
bazel_skylib = gh_facebook_kuro_shims_meta
buck = gh_facebook_kuro_shims_meta
fbcode = gh_facebook_kuro_shims_meta
fbcode_macros = gh_facebook_kuro_shims_meta
fbsource = gh_facebook_kuro_shims_meta
shim = gh_facebook_kuro_shims_meta
toolchains = gh_facebook_kuro_shims_meta

[external_cells]
# prelude = bundled  # DISABLED: Phase 8c-interim
