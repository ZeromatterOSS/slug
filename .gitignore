/target/
Cargo.lock
buck-out
bazel-external
# Kuro-generated apparent-name symlinks (kuro_core/src/cells.rs::ensure_external_symlink).
# Bazel keeps externals under <output_base>/external/, not at workspace root —
# kuro's convenience symlinks here are ephemeral and per-user.
external/
/.direnv
.buckconfig.local
.envrc.local

# symlinks
/examples/with_prelude/prelude
/examples/with_prelude/third-party/ocaml/opam
/examples/with_prelude/third-party/haskell/ghc
/examples/with_prelude/third-party/ocaml/standard_library

# Claude Code ctags index
.claude/tags
kuro

# Python bytecode and test caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
examples/hello_world/library.exp
examples/hello_world/library.lib
kuro.exe
tests/manual_test/**

# Benchmark artifacts: keep FINDINGS.md + summary.json + wall.txt;
# skip the large event logs and captured stderr.
benchmarks/**/*.pb.zst
benchmarks/**/build.log
benchmarks/**/summary.err
