load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library", "cc_test")

cc_library(
    name = "hello_lib",
    srcs = ["hello.c"],
)

cc_binary(
    name = "hello_bin",
    srcs = ["hello_test.c"],
    deps = [":hello_lib"],
)

cc_test(
    name = "hello_test",
    srcs = ["hello_test.c"],
    deps = [":hello_lib"],
)

cc_test(
    name = "hello_test_static",
    srcs = ["hello_test.c"],
    deps = [":hello_lib"],
    linkstatic = True,
)
