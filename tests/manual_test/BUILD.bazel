# Manual test BUILD file for bzlmod features
#
# Run: ../../target/release/kuro targets root//:
# This should print version info and test results.

# Test 2: Load from @bazel_skylib (BCR module)
# Should succeed - simple .bzl file with no external deps
load("@bazel_skylib//lib:dicts.bzl", "dicts")

# Test 3: Load paths.bzl (another simple module)
load("@bazel_skylib//lib:paths.bzl", "paths")

# Test 5: Load from @bazel_tools (bundled cell)
# This tests that visibility() function works, which was blocking bazel_tools file loading
load("@bazel_tools//tools/build_defs/repo:cache.bzl", "CANONICAL_ID_DOC")

# Test 4: Load bazel_features version comparison utility
load("@bazel_features//private:util.bzl", _bazel_version_ge = "ge")

# Test 1: native.bazel_version
# Should print "9.0.0-kuro"
_version = native.bazel_version

print("Test 1 - native.bazel_version:", _version)

_merged = dicts.add(
    {
        "a": 1,
        "b": 2,
    },
    {"c": 3},
)

print("Test 2 - bazel_skylib dicts.add:", _merged)

_basename = paths.basename("/foo/bar/baz.txt")

print("Test 3 - bazel_skylib paths.basename:", _basename)

# Test 4: Version check using bazel_features utility
# This is how real rulesets check Bazel version compatibility
_version_ok = _bazel_version_ge("9.0.0-pre.20250911")

print("Test 4 - bazel_features version >= 9.0.0-pre.20250911:", _version_ok)

# The file defines CANONICAL_ID_DOC constant - if we can access it, the load worked
print(
    "Test 5 - @bazel_tools cache.bzl loaded:",
    len(CANONICAL_ID_DOC) > 0,
)

# Note: http.bzl requires repository_rule which is Phase 5 work (module extensions)
# load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")  # Blocked: needs repository_rule

# Test 6: cc_common module (Phase 6)
# Testing that cc_common has the internal_DO_NOT_USE attribute
# Full rules_cc loading is blocked on transitive dependency resolution (bzlmod MVS)
_has_internal = hasattr(cc_common, "internal_DO_NOT_USE")
print("Test 6 - cc_common.internal_DO_NOT_USE exists:", _has_internal)

# Test 7: cc_common methods exist
_has_empty_vars = hasattr(cc_common, "empty_variables")
_has_get_tool = hasattr(cc_common, "get_tool_for_action")
print("Test 7 - cc_common methods exist:", _has_empty_vars and _has_get_tool)

# Test 8: Get the internal API and verify it works
_internal = cc_common.internal_DO_NOT_USE
print("Test 8 - cc_common.internal_DO_NOT_USE returned:", type(_internal))

# Test 9: Provider globals are None (per Bazel's CcRules.java)
# These are defined by rules_cc in Starlark, not as native builtins
_ccinfo_is_none = CcInfo == None
_debug_pkg_is_none = DebugPackageInfo == None
_shared_lib_is_none = CcSharedLibraryInfo == None
_protoinfo_is_none = ProtoInfo == None
print("Test 9 - CcInfo is None:", _ccinfo_is_none)
print("Test 9 - DebugPackageInfo is None:", _debug_pkg_is_none)
print("Test 9 - CcSharedLibraryInfo is None:", _shared_lib_is_none)
print("Test 9 - ProtoInfo is None:", _protoinfo_is_none)

# Test 10: CcToolchainConfigInfo should NOT exist as a global
# It's created via cc_common.create_cc_toolchain_config_info()
# This test would fail if we tried to access CcToolchainConfigInfo directly

# Test 10: cc_common.CcToolchainInfo should still work
_cc_toolchain_info = cc_common.CcToolchainInfo
print("Test 10 - cc_common.CcToolchainInfo exists:", _cc_toolchain_info != None)

# Test 11: Load Starlark cc_common helpers from bazel_tools
load("@bazel_tools//tools/cpp:cc_common.bzl", "cc_common_helpers")

# Verify the Starlark helpers work
_starlark_tool = cc_common_helpers.get_tool_for_action(None, "c++-compile")
print("Test 11 - Starlark cc_common_helpers.get_tool_for_action:", _starlark_tool)

# Test 12: Load Starlark proto_common helpers
load("@bazel_tools//tools/build_defs/proto:proto_common.bzl", "proto_common_helpers")

_proto_flag = proto_common_helpers.proto_path_flag(None)
print("Test 12 - Starlark proto_common_helpers.proto_path_flag:", _proto_flag)

# Test 13: subrule() built-in exists
_has_subrule = hasattr(native, "subrule") or "subrule" in dir()
print("Test 13 - subrule built-in exists:", _has_subrule)

# Test 14: rules_cc loading (now with subrule() implemented)
# PROGRESS: Provider registrations fixed (CcInfo, DebugPackageInfo, etc. are now None)
# PROGRESS: Starlark cc_common/proto_common helpers now available
# PROGRESS: subrule() built-in implemented
load("@rules_cc//cc:defs.bzl", "cc_library")
print("Test 14 - rules_cc loaded successfully!")

print("All manual tests passed!")
