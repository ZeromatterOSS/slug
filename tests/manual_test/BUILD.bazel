# Test for Phase 8d - Aspect shadow graph propagation
# Uses collect_aspect which tries to access dep[CollectNamesInfo] from dependencies

load(":test_aspect_8c.bzl", "test_rule")

# Create a dependency chain: c -> b -> a
test_rule(name = "a")
test_rule(name = "b", deps = [":a"])
test_rule(name = "c", deps = [":b"])

# Create a wider dependency graph (diamond): d -> [b, c]
test_rule(name = "d", deps = [":b", ":c"])

