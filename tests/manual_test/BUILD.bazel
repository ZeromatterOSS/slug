# =============================================================================
# Phase 14: genrule integration test
# =============================================================================
genrule(
    name = "hello_genrule",
    srcs = ["hello.c"],
    outs = ["hello_genrule_out.txt"],
    cmd = "echo 'Generated from $(SRCS)' > $(OUTS)",
)

genrule(
    name = "hello_genrule_cp",
    srcs = ["hello.c"],
    outs = ["hello_copy.c"],
    cmd = "cp $< $@",
)

# Test $(location :target) and $(execpath :target) expansion in genrule cmd.
# The cmd uses $(location :hello_genrule_cp) to reference the output of another genrule.
genrule(
    name = "hello_genrule_location",
    srcs = [":hello_genrule_cp"],
    outs = ["hello_location_out.txt"],
    cmd = "echo 'location=$(location :hello_genrule_cp) execpath=$(execpath :hello_genrule_cp)' > $(OUTS)",
)

