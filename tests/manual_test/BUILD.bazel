# =============================================================================
# Phase 8f/8g: rules_cc loading and instantiation test
# Provider access now works (Phase 6). Next blocker: implicit attributes
# (_def_parser has computed default function).
# =============================================================================
load("@rules_cc//cc:defs.bzl", "cc_library", "cc_binary")
load(":debug_cc_library.bzl", "debug_cc_library")

# WORKAROUND: rules_cc's cc_binary.bzl uses Label("//:link_extra_lib") which
# should resolve to @rules_cc//:link_extra_lib, but due to Label resolution
# currently using BUILD file context instead of .bzl file context, it resolves
# to this package. Create an empty cc_library to unblock builds.
# TODO(label): Fix Label() resolution to use .bzl file's repository context.
cc_library(
    name = "link_extra_lib",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "hello_lib",
    srcs = ["hello.c"],
)

cc_binary(
    name = "hello_bin",
    srcs = ["main.c"],
    deps = [":hello_lib"],
)

# Debug wrapper to trace cc_library analysis
debug_cc_library(
    name = "debug_hello_lib",
    srcs = ["hello.c"],
)

# Debug wrapper to trace cc_binary all_deps issue
load(":debug_cc_binary.bzl", "debug_cc_binary")

debug_cc_binary(
    name = "debug_hello_bin",
    deps = [":hello_lib"],
)

