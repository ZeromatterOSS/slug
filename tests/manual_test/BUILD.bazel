# select() test: uses config_setting + platform for conditional deps.
# Test with: kuro build //:select_test --target-platforms=//:linux_platform
# Expected: on linux_platform, selects hello.c; on macos_platform, selects lib.rs
# The "//conditions:default" arm enables building without a specific platform.
filegroup(
    name = "select_test",
    srcs = select({
        "//:is_linux": ["hello.c"],
        "//:is_macos": ["lib.rs"],
        "//conditions:default": [],
    }),
)

