load(":defs.bzl", "bool_flag", "collect_files", "select_value", "sibling_file", "stamp_file_info", "string_flag", "write_list")

# === filegroup tests ===

filegroup(
    name = "source_files",
    srcs = [
        "defs.bzl",
        "MODULE.bazel",
    ],
)

collect_files(
    name = "collected_filegroup",
    deps = [":source_files"],
)

# === alias tests ===

write_list(
    name = "original",
    items = ["hello", "world"],
)

alias(
    name = "aliased",
    actual = ":original",
)

# === select() with //conditions:default ===

select_value(
    name = "select_default",
    value = select({
        "//conditions:default": "default_value",
    }),
)

# === constraint_setting + constraint_value + config_setting ===

constraint_setting(name = "my_setting")

constraint_value(
    name = "my_value_a",
    constraint_setting = ":my_setting",
)

constraint_value(
    name = "my_value_b",
    constraint_setting = ":my_setting",
)

config_setting(
    name = "config_a",
    constraint_values = [":my_value_a"],
)

config_setting(
    name = "config_b",
    constraint_values = [":my_value_b"],
)

select_value(
    name = "select_with_constraint",
    value = select({
        ":config_a": "config_a_selected",
        ":config_b": "config_b_selected",
        "//conditions:default": "default_selected",
    }),
)

# === platform definition (using local constraint settings) ===

constraint_setting(name = "os")

constraint_value(
    name = "linux",
    constraint_setting = ":os",
)

constraint_value(
    name = "macos",
    constraint_setting = ":os",
)

platform(
    name = "linux_platform",
    constraint_values = [":linux"],
)

platform(
    name = "macos_platform",
    constraint_values = [":macos"],
)

# === genrule tests ===

genrule(
    name = "genrule_basic",
    outs = ["genrule_basic.txt"],
    cmd = "echo 'hello from genrule' > $@",
)

genrule(
    name = "genrule_srcs",
    srcs = ["defs.bzl"],
    outs = ["genrule_srcs.txt"],
    cmd = "echo $(SRCS) > $@",
)

genrule(
    name = "genrule_multi_outs",
    outs = ["multi_a.txt", "multi_b.txt"],
    cmd = "echo 'a' > $(@D)/multi_a.txt && echo 'b' > $(@D)/multi_b.txt",
)

genrule(
    name = "genrule_cmd_bash",
    outs = ["genrule_cmd_bash.txt"],
    cmd = "echo 'generic' > $@",
    cmd_bash = "echo 'from_bash' > $@",
)

genrule(
    name = "genrule_location",
    srcs = ["defs.bzl"],
    outs = ["genrule_location.txt"],
    cmd = "echo $(location :defs.bzl) > $@",
)

genrule(
    name = "genrule_select_cmd",
    outs = ["genrule_select_cmd.txt"],
    cmd = select({
        "//conditions:default": "echo 'selected_default' > $@",
    }),
)

genrule(
    name = "genrule_execpath",
    srcs = ["defs.bzl"],
    outs = ["genrule_execpath.txt"],
    cmd = "echo $(execpath :defs.bzl) > $@",
)

genrule(
    name = "genrule_bindir",
    outs = ["genrule_bindir.txt"],
    cmd = "echo $(BINDIR) > $@",
)

genrule(
    name = "genrule_ruledir",
    outs = ["genrule_ruledir.txt"],
    cmd = "echo $(@D) > $@",
)

# Windows-specific shell selection: cmd_ps (PowerShell) and cmd_bat (CMD.exe)
# On Windows: cmd_ps > cmd_bat > cmd_bash > cmd priority order.
# On non-Windows: cmd_ps/cmd_bat are ignored; cmd_bash > cmd.

genrule(
    name = "genrule_cmd_ps",
    outs = ["genrule_cmd_ps.txt"],
    cmd = "echo generic > $@",
    cmd_ps = "Set-Content -Path $(OUTS) -Value from_powershell",
)

genrule(
    name = "genrule_cmd_bat",
    outs = ["genrule_cmd_bat.txt"],
    cmd = "echo generic > $@",
    cmd_bat = "echo from_cmd> $(OUTS)",
)

genrule(
    name = "genrule_cmd_ps_priority",
    outs = ["genrule_cmd_ps_priority.txt"],
    cmd = "echo generic > $@",
    cmd_bat = "echo from_bat > $(OUTS)",
    cmd_ps = "Set-Content -Path $(OUTS) -Value from_ps_wins",
)

# === sh_binary test ===

sh_binary(
    name = "hello_sh",
    srcs = ["hello.sh"],
)

# === sh_library test ===

sh_library(
    name = "hello_sh_lib",
    srcs = ["hello.sh"],
)

# === sh_test test ===

sh_test(
    name = "hello_sh_test",
    srcs = ["hello.sh"],
)

# === test_suite test ===

test_suite(
    name = "all_sh_tests",
    tests = [":hello_sh_test"],
)

# === genrule with tools ===

sh_binary(
    name = "echo_tool",
    srcs = ["hello.sh"],
)

genrule(
    name = "genrule_with_tool",
    outs = ["genrule_with_tool.txt"],
    tools = [":echo_tool"],
    cmd = "bash $(location :echo_tool) > $@",
)

# === select() with platform resolution ===

config_setting(
    name = "linux_os_config",
    constraint_values = [":linux"],
)

config_setting(
    name = "macos_os_config",
    constraint_values = [":macos"],
)

select_value(
    name = "select_platform",
    value = select({
        ":linux_os_config": "linux_selected",
        ":macos_os_config": "macos_selected",
        "//conditions:default": "no_platform_selected",
    }),
)

# === config.bool() build settings with flag_values ===

bool_flag(
    name = "my_bool_flag",
    build_setting_default = False,
)

config_setting(
    name = "bool_flag_true",
    flag_values = {"//:my_bool_flag": "True"},
)

config_setting(
    name = "bool_flag_false",
    flag_values = {"//:my_bool_flag": "False"},
)

select_value(
    name = "select_by_bool_flag",
    value = select({
        ":bool_flag_true": "flag_is_true",
        ":bool_flag_false": "flag_is_false",
        "//conditions:default": "no_flag",
    }),
)

# === config.string() build settings with flag_values ===

string_flag(
    name = "my_string_flag",
    build_setting_default = "default_val",
)

config_setting(
    name = "string_flag_is_default",
    flag_values = {"//:my_string_flag": "default_val"},
)

select_value(
    name = "select_by_string_flag",
    value = select({
        ":string_flag_is_default": "default_selected",
        "//conditions:default": "fallback_selected",
    }),
)

# === label_flag with flag_values in config_setting ===

label_flag(
    name = "my_label_flag",
    build_setting_default = "//:my_toolchain_type",
)

config_setting(
    name = "using_default_label",
    flag_values = {"//:my_label_flag": "//:my_toolchain_type"},
)

config_setting(
    name = "using_other_label",
    flag_values = {"//:my_label_flag": "//:nonexistent"},
)

select_value(
    name = "select_by_label_flag",
    value = select({
        ":using_default_label": "default_flag_selected",
        "//conditions:default": "fallback_selected",
    }),
)

# === toolchain_type and toolchain tests ===

toolchain_type(
    name = "my_toolchain_type",
)

sh_binary(
    name = "my_toolchain_impl",
    srcs = ["hello.sh"],
)

toolchain(
    name = "my_toolchain",
    toolchain_type = ":my_toolchain_type",
