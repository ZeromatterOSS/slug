load(
    ":defs.bzl",
    "depset_bridge_rule",
    "depset_consumer",
    "depset_default_infer_rule",
    "depset_keyword_rule",
    "depset_len_rule",
    "depset_mismatch_rule",
    "depset_order_attr_rule",
    "depset_order_rule",
    "depset_producer",
    "depset_topological_diamond_rule",
    "depset_union_rule",
)

package(default_visibility = ["//visibility:public"])

depset_order_rule(
    name = "preorder",
    order = "preorder",
)

depset_order_rule(
    name = "postorder",
    order = "postorder",
)

depset_order_rule(
    name = "topological",
    order = "topological",
)

depset_order_rule(
    name = "default",
    order = "default",
)

depset_default_infer_rule(
    name = "default_infer",
)

depset_topological_diamond_rule(
    name = "topological_diamond",
)

depset_mismatch_rule(
    name = "mismatch",
)

# Cross-rule depset traversal
depset_producer(
    name = "depset_producer",
)

depset_consumer(
    name = "depset_consumer",
    dep = ":depset_producer",
)

# Test depset() with keyword direct= and transitive= args
depset_keyword_rule(
    name = "depset_keyword",
)

# Negative parity test for depset | operator (union)
depset_union_rule(
    name = "depset_union",
)

# Negative parity test for depset.order attribute
depset_order_attr_rule(
    name = "depset_order_attr",
)

# Negative parity test for len(depset)
depset_len_rule(
    name = "depset_len",
)

depset_bridge_rule(
    name = "depset_bridge",
)
