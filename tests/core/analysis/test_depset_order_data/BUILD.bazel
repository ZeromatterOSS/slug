load(
    ":defs.bzl",
    "depset_consumer",
    "depset_default_infer_rule",
    "depset_mismatch_rule",
    "depset_order_rule",
    "depset_producer",
)

package(default_visibility = ["//visibility:public"])

depset_order_rule(
    name = "preorder",
    order = "preorder",
)

depset_order_rule(
    name = "postorder",
    order = "postorder",
)

depset_order_rule(
    name = "topological",
    order = "topological",
)

depset_order_rule(
    name = "default",
    order = "default",
)

depset_default_infer_rule(
    name = "default_infer",
)

depset_mismatch_rule(
    name = "mismatch",
)

# Cross-rule depset traversal
depset_producer(
    name = "depset_producer",
)

depset_consumer(
    name = "depset_consumer",
    dep = ":depset_producer",
)
