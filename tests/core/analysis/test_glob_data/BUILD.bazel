load(":defs.bzl", "files_list")

# Test glob with all .txt files in src/
files_list(
    name = "all_txt",
    srcs = glob(["src/**/*.txt"]),
)

# Test glob with all .py files
files_list(
    name = "all_py",
    srcs = glob(["src/**/*.py"]),
)

# Test glob with exclude
files_list(
    name = "txt_no_b",
    srcs = glob(["src/**/*.txt"], exclude = ["src/b.txt"]),
)

# Test glob with multiple patterns
files_list(
    name = "multi_pattern",
    srcs = glob(["src/**/*.txt", "data/**/*.json"]),
)

# Test glob that returns empty list (no matches)
files_list(
    name = "no_match",
    srcs = glob(["src/**/*.cpp"]),
)

# Test glob in package root
files_list(
    name = "root_files",
    srcs = glob(["data/*.json"]),
)

# Test glob case sensitivity: "SRC/**/*.txt" should NOT match files in "src/"
files_list(
    name = "case_sensitive",
    srcs = glob(["SRC/**/*.txt"]),
)

# Test glob allow_empty=True with no matches (default, should succeed)
files_list(
    name = "allow_empty_true",
    srcs = glob(["src/**/*.nonexistent"], allow_empty = True),
)

# Test glob exclude_directories parameter (accepted, default=1)
files_list(
    name = "exclude_dirs",
    srcs = glob(["src/**/*.txt"], exclude_directories = 1),
)
