# Bucket-C fixture (Plan 35.6a). Uses kuro-specific knobs not yet
# migrated to CLI flags. See thoughts/shared/research/2026-05-04-fixture-bucket-classification.md

[cells]
  root = .

[external_cells]
  prelude = bundled

[buildfile]
  name = TARGETS.fixture

[kuro]
  error_on_dep_only_incompatible = \
    //dep_incompatible:dep_incompatible_conf1, \
    //dep_incompatible:dep_incompatible_conf2

[build]
  execution_platforms = //exec_dep:execution_platforms
