[cells]
gh_facebook_kuro = .
gh_facebook_kuro_shims_meta = shim

[cell_aliases]
root = gh_facebook_kuro

[oss]
internal_cell = fbcode
stripped_root_dirs = kuro

[project]
ignore = \
    app/kuro_explain, \
    app_dep_graph_rules, \
    examples, \
    integrations/rust-project/tests, \
    tests

[rust]
default_edition = 2024
