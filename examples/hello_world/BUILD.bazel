# Bazel-compatible BUILD file for hello_world example
# This demonstrates Bazel syntax (cc_binary, cc_library)

load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")

cc_binary(
    name = "main",
    srcs = ["main.cpp"],
    deps = [":print"],
)

cc_library(
    name = "print",
    srcs = ["library.cpp"],
    hdrs = glob(["**/*.hpp"]),
    visibility = ["//visibility:public"],
)
